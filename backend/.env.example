# Pulse CRM Backend Environment Variables
# Copy this file to .env

# ── Database ────────────────────────────────────────
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pulse_crm
DATABASE_URL=postgresql+psycopg://postgresql_o4dc_user:password@host/db
# ── App Settings ────────────────────────────────────
APP_NAME=Pulse CRM
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
