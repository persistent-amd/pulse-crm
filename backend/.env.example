# Pulse CRM Backend Environment Variables
# Copy this file to .env

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://pulse_user:pulse_pass@localhost:5432/pulse_crm

# ── App Settings ────────────────────────────────────
APP_NAME=Pulse CRM
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
